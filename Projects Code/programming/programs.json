                         "code":  "def maxSubArray(nums):\n    max_sum = nums[0]\n    curr_sum = nums[0]\n    for n in nums[1:]:\n        curr_sum = max(n, curr_sum + n)\n        max_sum = max(max_sum, curr_sum)\n    return max_sum\n\nnums = list(map(int, input().strip(\u0027[]\u0027).split(\u0027,\u0027)))\nprint(maxSubArray(nums))",
