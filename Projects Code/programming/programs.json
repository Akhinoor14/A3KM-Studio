  "programs": [
    {
      "id": "prog-001",
      "title": "Two Sum",
      "slug": "two-sum",
      "language": "python",
      "category": "problem-solving",
      "subcategory": "Arrays & Strings",
      "difficulty": "Easy",
      "difficultyLevel": 1,
      "source": "LeetCode",
      "sourceNumber": "1",
      "sourceUrl": "",
      "codeFile": "../../Projects Storage/Programming/python/problem-solving/arrays-strings/two-sum.py",
      "description": "Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target. You may assume that each input would have exactly one solution, and you may not use the same element twice. You can return the answer in any order.",
      "examples": [
        {
          "input": "nums = [2,7,11,15], target = 9",
          "output": "[0,1]",
          "explanation": "Because nums[0] + nums[1] == 9, we return [0, 1]."
        },
        {
          "input": "nums = [3,2,4], target = 6",
          "output": "[1,2]",
          "explanation": "Because nums[1] + nums[2] == 6, we return [1, 2]."
        },
        {
          "input": "nums = [3,3], target = 6",
          "output": "[0,1]",
          "explanation": "Because nums[0] + nums[1] == 6, we return [0, 1]."
        }
      ],
      "constraints": [
        "2 ≤ nums.length ≤ 10⁴",
        "-10⁹ ≤ nums[i] ≤ 10⁹",
        "-10⁹ ≤ target ≤ 10⁹",
        "Only one valid answer exists"
      ],
      "approach": "HashMap single pass — for each number, store its complement (target - n) as key. Check if current number already exists as a key.",
      "timeComplexity": "O(n)",
      "spaceComplexity": "O(n)",
      "tags": ["HashMap", "Array", "Classic"],
      "code": "def twoSum(nums, target):\n    seen = {}\n    for i, n in enumerate(nums):\n        comp = target - n\n        if comp in seen:\n            return [seen[comp], i]\n        seen[n] = i\n    return []\n\n# Read input\nnums = list(map(int, input().strip('[]').split(',')))\ntarget = int(input())\nprint(twoSum(nums, target))",
      "hasTestCases": true,
      "testCases": [
        { "input": "[2,7,11,15]\n9", "expectedOutput": "[0, 1]", "label": "Basic" },
        { "input": "[3,2,4]\n6", "expectedOutput": "[1, 2]", "label": "Non-obvious" },
        { "input": "[3,3]\n6", "expectedOutput": "[0, 1]", "label": "Duplicate" }
      ]description": "Given an integer array nums, find the subarray with the largest sum, and return its sum. A subarray is a contiguous non-empty sequence of elements within an array.",
      "examples": [
        {
          "input": "nums = [-2,1,-3,4,-1,2,1,-5,4]",
          "output": "6",
          "explanation": "The subarray [4,-1,2,1] has the largest sum 6."
        },
        {
          "input": "nums = [1]",
          "output": "1",
          "explanation": "The subarray is [1] which has the sum 1."
        },
        {
          "input": "nums = [5,4,-1,7,8]",
          "output": "23",
          "explanation": "The subarray [5,4,-1,7,8] has the largest sum 23."
        }
      ],
      "constraints": [
        "1 ≤ nums.length ≤ 10⁵",
        "-10⁴ ≤ nums[i] ≤ 10⁴"
      ],
      ",
      "sampleInput": "[2,7,11,15]\n9",
      "sampleOutput": "[0, 1]",
      "notes": "Classic starter problem. Key insight: for each number n, we need target-n. Store seen numbers in a hashmap for O(1) lookup.",
      "relatedProblems": [
        { "title": "Two Sum II", "source": "LeetCode", "number": "167" },
        { "title": "Three Sum", "source": "LeetCode", "number": "15" }
      ],
      "dateAdded": "2026-03-06",
      "featured": true
