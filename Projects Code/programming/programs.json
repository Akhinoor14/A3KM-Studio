    {
      "id": "prog-001",
      "title": "Two Sum",
      "slug": "two-sum",
      "language": "python",
      "category": "problem-solving",
      "subcategory": "Arrays & Strings",
      "difficulty": "Easy",
      "difficultyLevel": 1,
      "source": "LeetCode",
      "sourceNumber": "1",
      "sourceUrl": "",
      "codeFile": "../../Projects Storage/Programming/python/problem-solving/arrays-strings/two-sum.py",
      "approach": "HashMap single pass — for each number, store its complement (target - n) as key. Check if current number already exists as a key.",
      "timeComplexity": "O(n)",
      "spaceComplexity": "O(n)",
      "tags": ["HashMap", "Array", "Classic"],
      "code": "def twoSum(nums, target):\n    seen = {}\n    for i, n in enumerate(nums):\n        comp = target - n\n        if comp in seen:\n            return [seen[comp], i]\n        seen[n] = i\n    return []\n\n# Read input\nnums = list(map(int, input().strip('[]').split(',')))\ntarget = int(input())\nprint(twoSum(nums, target))",
      "hasTestCases": true,
      "testCases": [
        { "input": "[2,7,11,15]\n9", "expectedOutput": "[0, 1]", "label": "Basic" },
        { "input": "[3,2,4]\n6", "expectedOutput": "[1, 2]", "label": "Non-obvious" },
        { "input": "[3,3]\n6", "expectedOutput": "[0, 1]", "label": "Duplicate" }
      ],
      "sampleInput": "[2,7,11,15]\n9",
      "sampleOutput": "[0, 1]",
      "notes": "Classic starter problem. Key insight: for each number n, we need target-n. Store seen numbers in a hashmap for O(1) lookup.",
      "relatedProblems": [
        { "title": "Two Sum II", "source": "LeetCode", "number": "167" },
        { "title": "Three Sum", "source": "LeetCode", "number": "15" }
      ],
      "dateAdded": "2026-03-06",
      "featured": true
    },
    {
      "id": "prog-002",
      "title": "Maximum Subarray",
      "slug": "maximum-subarray",
      "language": "python",
      "category": "problem-solving",
      "subcategory": "Dynamic Programming",
      "difficulty": "Medium",
      "difficultyLevel": 2,
      "source": "LeetCode",
      "sourceNumber": "53",
      "sourceUrl": "",
      "codeFile": "../../Projects Storage/Programming/python/problem-solving/dynamic-programming/maximum-subarray.py",
      "approach": "Kadane's Algorithm — track current running sum and global max. If current sum goes negative, reset to current element.",
      "timeComplexity": "O(n)",
      "spaceComplexity": "O(1)",
      "tags": ["Dynamic Programming", "Array", "Kadane's Algorithm"],
      "code": "def maxSubArray(nums):\n    max_sum = nums[0]\n    curr_sum = nums[0]\n    for n in nums[1:]:\n        curr_sum = max(n, curr_sum + n)\n        max_sum = max(max_sum, curr_sum)\n    return max_sum\n\nnums = list(map(int, input().strip('[]').split(',')))\nprint(maxSubArray(nums))",
      "hasTestCases": true,
      "testCases": [
        { "input": "[-2,1,-3,4,-1,2,1,-5,4]", "expectedOutput": "6", "label": "Classic" },
        { "input": "[1]", "expectedOutput": "1", "label": "Single Element" },
        { "input": "[5,4,-1,7,8]", "expectedOutput": "23", "label": "All Positive" }
      ],
      "sampleInput": "[-2,1,-3,4,-1,2,1,-5,4]",
      "sampleOutput": "6",
      "notes": "Kadane's Algorithm is the key pattern here. The subarray [4,-1,2,1] has the largest sum = 6.",
      "relatedProblems": [
        { "title": "Maximum Product Subarray", "source": "LeetCode", "number": "152" }
      ],
      "dateAdded": "2026-03-06",
      "featured": true
    }
