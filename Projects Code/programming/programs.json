                                              "explanation":  "The subarray [5,4,-1,7,8] has the largest sum 23."
                                          }
                                      ],
                         "constraints":  [
                                             "1 â‰¤ nums.length â‰¤ 10âµ",
                                             "-10â´ â‰¤ nums[i] â‰¤ 10â´"
                                         ],
                         "approach":  "Kadane\u0027s Algorithm â€” track current running sum and global max. If current sum goes negative, reset to current element.",
                         "timeComplexity":  "O(n)",
                         "spaceComplexity":  "O(1)",
                         "tags":  [
                                      "Dynamic Programming",
